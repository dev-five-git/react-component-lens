{
  "name": "react-component-lens-workspace",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-five-git/react-component-lens"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "build:production": "bun run --filter '*' build:production",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run lint:js && bun run lint:rust",
    "lint:js": "oxlint .",
    "lint:rust": "bun run lint:rust:fmt && bun run lint:rust:clippy && bun run lint:rust:clippy:wasm",
    "lint:rust:fmt": "cargo fmt --all -- --check",
    "lint:rust:clippy": "cargo clippy --workspace --exclude zed-react-component-lens --all-targets -- -D warnings",
    "lint:rust:clippy:wasm": "cargo clippy --target wasm32-wasip1 --release -p zed-react-component-lens -- -D warnings",
    "lint:fix": "oxlint . --fix && cargo fmt --all",
    "test": "bun run test:rust && bun run test:js && bun run test:wasm && bun run test:fuzz",
    "test:rust": "cargo test --workspace --exclude zed-react-component-lens",
    "test:js": "bun test",
    "test:wasm": "cargo build --target wasm32-wasip1 --release -p zed-react-component-lens",
    "test:fuzz": "bun run test:fuzz:build && bun run --filter @react-component-lens/conformance-harness fuzz:ci",
    "test:fuzz:build": "cargo build --release -p core-rs --bin emit-canonical",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "25.9.1",
    "bun-types": "^1.3.14",
    "eslint-plugin-devup": "^2.0.19",
    "globals": "17.6.0",
    "husky": "^9.1.7",
    "oxlint": "^1.67"
  }
}
