{
  "name": "react-component-lens-workspace",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-five-git/react-component-lens"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "build:production": "bun run --filter '*' build:production",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "test": "bun test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "25.5.0",
    "bun-types": "^1.3.10",
    "eslint-plugin-devup": "^2.0.17",
    "globals": "17.4.0",
    "husky": "^9.1.7",
    "oxlint": "^1.55"
  }
}
